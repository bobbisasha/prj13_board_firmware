               .segment begin "Task: UART Emulator"
               uartEmulator/initialize:
               ;?
               uartEmulator/initializeDone:
0104 ---- adb7                         rts




               uartEmulator/execute:
               ;? // Run the UART emulator until the application sets state.exit
               ;?
               ;? //power ON SensorVDD PIN
               ;? gpioSetOutput(AUXIO_O_A02YYUW_VDDPIN);
0105 ---- 660f                         iobset      #(10 & 0x7), [#(IOP_AIODIO0_GPIODOUT + (10 >> 3))]
               ;?
               ;? //waiting for sensor settling time
               ;? fwDelayUs(100000, FW_DELAY_RANGE_100_MS);
0106 ---- 7093                         ld          R7, #(((100000 * 24 ) + ((1 << 14) - 1)) >> 14)
0107 ---- 600e                         ld          R6, #14
0108 ---- 150d                         jsr         FwDelay
               ;?
               ;? //serial read
               ;? uartEmulator();
0109 ---- 1513                         jsr         UartEmulator
               ;?
               ;? //power OFF SensorVDD PIN
               ;? gpioClearOutput(AUXIO_O_A02YYUW_VDDPIN);
010a ---- 460f                         iobclr      #(10 & 0x7), [#(IOP_AIODIO0_GPIODOUT + (10 >> 3))]
               uartEmulator/executeDone:
010b ---- adb7                         rts




               uartEmulator/terminate:
               ;?
               uartEmulator/terminateDone:
010c ---- adb7                         rts
               .segment end "Task: UART Emulator"


               .segment begin "Procedure Library"
               ; 3 + 5 CPU cycles = 16 clock cycles = 0.66 microsecond are added to the specified delay (parameter
               ; loading and timer configuration)
               ;
               ; PARAMETERS:
               ;     R7 = Delay
               ;     R6 = Prescaler exponent
               ;
               ; CLOBBERS:
               ;     R6
               FwDelay:
                                       ; Set the delay
010d ---- fb0c                         out         R7, [#IOP_TIMER01_T0TARGET]

                                       ; Configure the timer (from clock, single-mode, prescaler exponent = R6)
010e ---- eda4                         lsl         R6, #4
010f ---- eb09                         out         R6, [#IOP_TIMER01_T0CFG]

                                       ; Start the timer, wait for it to trigger, and stop it
0110 ---- 640b                         iobset      #0, [#IOP_TIMER01_T0CTL]
0111 ---- cdb1                         wev1        #WEVSEL_TIMER0
0112 ---- adb7                         rts




               ; TIMER0 event rate = 4 times the UART baud rate
               ;
               ; R7    TX bit counter
               ; R6    TX shift register
               ; R5    RX bit counter / RX new head index / RX timeout counter
               ; R4    RX shift register
               ; R3    RX data storage pointer (last word)
               ; R2    RX idle counter
               ; R1    Temporary variables
               ; R0    Temporary variables (special functionality)


               ; Flags set for each RX byte
               .define BV_UART_RX_TIMEOUT                      0x0800
               .define BV_UART_RX_OVERFLOW                     0x0400
               .define BV_UART_RX_BREAK                        0x0200
               .define BV_UART_RX_FRAMING_ERROR                0x0100

               ; Alert-generating events
               .define BV_UART_ALERT_RX_FIFO_ABOVE_THR         0x0001
               .define BV_UART_ALERT_RX_BYTE_TIMEOUT           0x0002
               .define BV_UART_ALERT_RX_BREAK_OR_FRAMING_ERROR 0x0004
               .define BV_UART_ALERT_TX_FIFO_BELOW_THR         0x0008



               UartEmulator:
                                       ; Disable RX idle timeout
0113 ---- 5000                         ld          R5, #0

                                       ; Set the default number of required idle half-bits before enabling RX
0114 ---- 2879                         ld          R2, [#uartTaskName/cfg/rxEnableReqIdleCount]

                                       ; Initialize state machine (function pointers)
0115 ---- 012d                         ld          R0, #UartEmulator/txIdle
0116 ---- 0e29                         st          R0, [#uartTxFptr]
0117 ---- 0156                         ld          R0, #UartEmulator/rxIdle
0118 ---- 0e2a                         st          R0, [#uartRxFptr]
0119 ---- 01c7                         ld          R0, #UartEmulator/sysCmd
011a ---- 0e2b                         st          R0, [#uartSysFptr]
011b 8602 0212                         ld          R0, #UartEmulator/txCheckRxStartDisabled
011d ---- 0e2c                         st          R0, [#uartTxCheckRxStartFptr]
011e 8602 021d                         ld          R0, #UartEmulator/sysCheckRxStartDisabled
0120 ---- 0e2d                         st          R0, [#uartSysCheckRxStartFptr]




               /mainLoop:
                                       ; 0: RX (oversampling)
0121 ---- 0a2a                         ld          R0, [#uartRxFptr]
0122 ---- cdb1                         wev1        #WEVSEL_TIMER0
0123 ---- 9db7                         jsr         R0

                                       ; 1: TX
0124 ---- 0a2c                         ld          R0, [#uartTxCheckRxStartFptr]
0125 ---- cdb1                         wev1        #WEVSEL_TIMER0
0126 ---- 9db7                         jsr         R0

                                       ; 2: RX (oversampling)
0127 ---- 0a2a                         ld          R0, [#uartRxFptr]
0128 ---- cdb1                         wev1        #WEVSEL_TIMER0
0129 ---- 9db7                         jsr         R0

                                       ; 3: System (jumps to the start of the main loop or returns)
012a ---- 0a2d                         ld          R0, [#uartSysCheckRxStartFptr]
012b ---- cdb1                         wev1        #WEVSEL_TIMER0
012c ---- 8db7                         jmp         R0






               ;; TX IDLE
               /txIdle:
                                       ; Start transmission of a new byte?
012d ---- 6902                         ld          R6, [#uartTaskName/state/txHead]
012e ---- 1903                         ld          R1, [#uartTaskName/state/txTail]
012f ---- 9d2e                         cmp         R1, R6
0130 ---- b604                         beq         /txIdleNoStart
               /txIdleCheckStartDelay:
                                           ; Load the data byte (LSB) and delay (MSB) into the shift register
0131 ---- 987a                             add         R1, #uartTaskName/input/pTxBuffer
0132 ---- ef09                             ld          R6, [R1]

                                           ; Proceed to "txStartBit" next
0133 ---- 1136                             ld          R1, #/txStartBit
0134 ---- 1e29                             st          R1, [#uartTxFptr]
               /txIdleNoStart:
                                       ; Done
0135 ---- adb7                         rts




               ;; TX START BIT
               /txStartBit:
                                       ; Delay the transmission? (remaining delay is in MSB of the shift register)
0136 8600 eaff                         cmp         R6, #0x00FF
0138 ---- 9e03                         bleu        /txStartBitNoDelay

                                           ; Decrement the delay
0139 86ff e800                             add         R6, #0xFF00
013b ---- 8e04                         bra         /txStartBitDone

                                       ; Otherwise ...
               /txStartBitNoDelay:
                                           ; Transmit the start bit
013c ---- 560f                             iobclr      #(AUXIO_UART_TX & 0x7), [#(IOP_AIODIO0_GPIODOUT + (AUXIO_UART_TX >> 3))]

                                           ; Initialize the bit counter used by "txDataBit"
013d ---- 7008                             ld          R7, #8

                                           ; Proceed to "txDataBit" next
013e ---- 1141                             ld          R1, #/txDataBit
013f ---- 1e29                             st          R1, [#uartTxFptr]
               /txStartBitDone:
                                       ; Done
0140 ---- adb7                         rts




               ;; TX DATA BIT
               /txDataBit:
                                       ; Transmit lsb of the shift register
0141 ---- ec01                         tst         R6, #0x0001
0142 ---- be02                         bnz         /txDataBitOutput1

                                           ; Transmit logical 0
0143 ---- 560f                             iobclr      #(AUXIO_UART_TX & 0x7), [#(IOP_AIODIO0_GPIODOUT + (AUXIO_UART_TX >> 3))]
0144 ---- 8e01                         bra         /txDataBitOutputDone
               /txDataBitOutput1:
                                           ; Transmit logical 1
0145 ---- 760f                             iobset      #(AUXIO_UART_TX & 0x7), [#(IOP_AIODIO0_GPIODOUT + (AUXIO_UART_TX >> 3))]
               /txDataBitOutputDone:
                                       ; Update the shift register
0146 ---- eda9                         lsr         R6, #1

                                       ; Proceed to "txStopBit" next when the msb has been transmitted (counter in R7
                                       ; goes from 8 to 0)
0147 ---- f8ff                         add         R7, #-1
0148 ---- be02                         bnz         /txDataBitNotMsb
0149 ---- 114c                             ld          R1, #/txStopBit
014a ---- 1e29                             st          R1, [#uartTxFptr]
               /txDataBitNotMsb:
                                       ; Done
014b ---- adb7                         rts




               ;; TX STOP BIT
               /txStopBit:
                                       ; Proceed to "txIdle" next, for a second stop bit
014c ---- 112d                         ld          R1, #/txIdle
014d ---- 1e29                         st          R1, [#uartTxFptr]

                                       ; Transmit the stop bit
