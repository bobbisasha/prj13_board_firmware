               uartEmulator/cfg/alertMask:
0075 ---- 0000                         dw          #0
               uartEmulator/cfg/alertRxFifoThr:
0076 ---- 0000                         dw          #0
               uartEmulator/cfg/alertTxFifoThr:
0077 ---- 0000                         dw          #0
               uartEmulator/cfg/rxByteTimeout:
